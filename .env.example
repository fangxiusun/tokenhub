# Server Configuration
PORT=3000
GIN_MODE=debug

# Database Configuration
# SQLite (default)
# SQL_DSN=

# MySQL
# SQL_DSN=user:password@tcp(localhost:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local

# PostgreSQL
# SQL_DSN=host=localhost user=user password=password dbname=dbname port=5432 sslmode=disable TimeZone=Asia/Shanghai

# Redis Configuration
REDIS_CONN_STRING=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Session Configuration
SESSION_SECRET=your-secret-key-change-this

# Security Configuration
CRYPTO_SECRET=your-crypto-secret-change-this

# CORS Configuration
CORS_ALLOW_ORIGINS=*

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Frontend Configuration
FRONTEND_BASE_URL=

# OAuth Configuration (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email Configuration (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
